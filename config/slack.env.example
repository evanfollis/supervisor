# Slack integration config. Copy to config/slack.env and fill in.
# The live file is gitignored; only this example is checked in.

# Bot token, starts with "xoxb-". Scopes required: chat:write, reactions:write,
# users:read (for presence), files:read (Stage 2), channels:history (Stage 2),
# channels:join (optional, for auto-join on add).
SLACK_BOT_TOKEN=

# Channel names or IDs. IDs are safer if channels get renamed.
SLACK_CHANNEL_SUPERVISOR=#supervisor-loop
SLACK_CHANNEL_OPS=#workspace-ops

# Stage 2 only (normalizer): inbound channel.
SLACK_CHANNEL_PRINCIPAL_NOTES=#principal-notes

# Optional overrides (defaults are derived from SUPERVISOR_ROOT / RUNTIME_ROOT).
# SUPERVISOR_ROOT=/opt/workspace/supervisor
# RUNTIME_ROOT=/opt/workspace/runtime
