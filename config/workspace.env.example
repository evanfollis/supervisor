# Workspace topology mode.
# legacy = current /opt/projects compatibility layout
# split  = target /opt/workspace/{supervisor,projects,runtime} layout
WORKSPACE_LAYOUT=legacy

# Uncomment and adjust during cutover.
# WORKSPACE_ROOT=/opt/workspace
# SUPERVISOR_ROOT=/opt/workspace/supervisor
# PROJECTS_ROOT=/opt/workspace/projects
# RUNTIME_ROOT=/opt/workspace/runtime
# WORKSPACE_INFRA_ROOT=/opt/workspace/supervisor
# WORKSPACE_SCRIPTS_ROOT=/opt/workspace/supervisor/scripts/lib
# WORKSPACE_SYSTEMD_ROOT=/opt/workspace/supervisor/systemd
# WORKSPACE_SESSION_CONF=/opt/workspace/supervisor/config/sessions.conf
# WORKSPACE_PROJECTS_CONF=/opt/workspace/supervisor/config/projects.conf

# Optional explicit entrypoints for systemd services.
# WORKSPACE_SESSION_SUPERVISOR=/opt/workspace/supervisor/scripts/lib/session-supervisor.sh
# WORKSPACE_SERVER_HEALTH_CAPTURE_SCRIPT=/opt/workspace/supervisor/scripts/lib/server-health-snapshot.sh
# WORKSPACE_SERVER_MAINTENANCE_SCRIPT=/opt/workspace/supervisor/scripts/lib/server-maintenance.sh
# WORKSPACE_SERVER_MAINTENANCE_SCHEDULE_SCRIPT=/opt/workspace/supervisor/scripts/lib/server-maintenance-schedule.sh
