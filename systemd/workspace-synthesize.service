[Unit]
Description=Workspace - cross-project synthesis (Opus, propose-only)
After=network.target

[Service]
Type=oneshot
User=root
Environment=HOME=/root
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
WorkingDirectory=/opt/workspace/supervisor
ExecStart=/opt/workspace/supervisor/scripts/lib/synthesize.sh
TimeoutStartSec=20min
StandardOutput=append:/var/log/workspace-synthesize.log
StandardError=append:/var/log/workspace-synthesize.log
