[Unit]
Description=Verify and repair workspace GitHub durability
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=HOME=/root
Environment="GIT_SSH_COMMAND=/usr/bin/ssh -o BatchMode=yes -o ConnectTimeout=10"
ExecStart=/opt/workspace/supervisor/scripts/lib/remote-durability.sh --repair --source cron
Nice=10
TimeoutStartSec=120
