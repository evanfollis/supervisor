{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "overall_status": {
      "type": "string",
      "enum": ["healthy", "watch", "action-required", "urgent"]
    },
    "summary": {
      "type": "string"
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "area": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["info", "watch", "action-required", "urgent"]
          },
          "evidence": { "type": "string" },
          "implication": { "type": "string" }
        },
        "required": ["area", "severity", "evidence", "implication"],
        "additionalProperties": false
      }
    },
    "maintenance_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["p1", "p2", "p3"]
          },
          "reason": { "type": "string" },
          "proposed_window": { "type": "string" },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "automation_candidate": { "type": "boolean" }
        },
        "required": ["title", "priority", "reason", "proposed_window", "commands", "automation_candidate"],
        "additionalProperties": false
      }
    },
    "handoff_required": {
      "type": "boolean"
    },
    "handoff_note": {
      "type": "string"
    }
  },
  "required": [
    "overall_status",
    "summary",
    "key_findings",
    "maintenance_tasks",
    "handoff_required",
    "handoff_note"
  ],
  "additionalProperties": false
}
